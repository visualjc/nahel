node_modules/
dist/
*.tsbuildinfo
.DS_Store
.env
.env.*

# ccpm scaffolding IS committed in this repo (overrides global gitignore):
# it is pinned temporary tooling + Stage B state that must travel via git.
!.claude/
.claude/settings.json
.claude/settings.local.json
.claude/.ccpmrc

# Ephemeral scaffolding run state — never project state (constitution: .claude/ is tooling-only)
.claude/state/
.claude/context/

# F7 skills dependency (ADR-0009): the clone cache and the restored skill
# symlinks are ENVIRONMENT — `nahel skills restore` reproduces them from
# skills.lock, so they never travel via git.
.nahel-skills/
.claude/skills/
